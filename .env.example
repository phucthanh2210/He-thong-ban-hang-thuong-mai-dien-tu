# Server
PORT=3000

# Database (Aiven MySQL)
DB_HOST=your-aiven-host.aivencloud.com
DB_PORT=12345
DB_USER=avnadmin
DB_PASS=your-password
DB_NAME=defaultdb

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL (for CORS - leave empty in production since frontend is served by same server)
FRONTEND_URL=
